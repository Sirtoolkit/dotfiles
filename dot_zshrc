# System essentials (normally from /etc/zshrc)
# Setup brew (cached for speed - 24h)
BREW_PREFIX_CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/brew_prefix"
if [[ -r "$BREW_PREFIX_CACHE" && $(($(date +%s) - $(stat -f%m "$BREW_PREFIX_CACHE" 2>/dev/null || echo 0))) -lt 86400 ]]; then
  BREW_PREFIX=$(<"$BREW_PREFIX_CACHE")
else
  BREW_PREFIX=$(brew --prefix 2>/dev/null || echo "/opt/homebrew")
  mkdir -p "$(dirname "$BREW_PREFIX_CACHE")"
  echo "$BREW_PREFIX" > "$BREW_PREFIX_CACHE"
fi

export HOMEBREW_PREFIX="$BREW_PREFIX"
export HOMEBREW_CELLAR="${BREW_PREFIX}/Cellar"
export HOMEBREW_REPOSITORY="${BREW_PREFIX}"
export PATH="${BREW_PREFIX}/bin:${BREW_PREFIX}/sbin${PATH+:$PATH}"
export MANPATH="${BREW_PREFIX}/share/man${MANPATH+:$MANPATH}:"
export INFOPATH="${BREW_PREFIX}/share/info:${INFOPATH:-}"

# User profile
[ ! -f "${XDG_CONFIG_HOME:-$HOME/.config}/shell/profile.sh" ] || source "${XDG_CONFIG_HOME:-$HOME/.config}/shell/profile.sh"

# Add Homebrew completions
if [[ -n "$BREW_PREFIX" ]]; then
  FPATH="${BREW_PREFIX}/share/zsh/site-functions:${FPATH}"
  PATH="${BREW_PREFIX}/opt/coreutils/libexec/gnubin:$PATH"
fi

# Completions - fast init
autoload -Uz compinit
compinit -C

# Git prompt
GIT_BRANCH=""
update_git_prompt() {
  GIT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || git describe --tags --exact-match 2>/dev/null || echo "")
}
setopt prompt_subst
PROMPT='%F{green}%n@%m%f:%F{cyan}%~%f %F{blue}${GIT_BRANCH}%f %F{yellow}$%f '
precmd_functions+=(update_git_prompt)

# History
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt appendhistory sharehistory

# Basic aliases
alias ls='ls --color=auto'
alias ll='ls -la'
alias la='ls -A'
alias l='ls -CF'
alias ..='cd ..'
alias ...='cd ../..'

# Key bindings
bindkey -e
bindkey '^[[A' history-beginning-search-backward
bindkey '^[[B' history-beginning-search-forward

# Syntax highlighting
source ~/.oh-my-zsh/custom/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh 2>/dev/null || true

# Autosuggestions
source ~/.oh-my-zsh/custom/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh 2>/dev/null || true

# zoxide - lazy load with common aliases
_load_zoxide() {
  if command -v zoxide &>/dev/null; then
    eval "$(zoxide init zsh)"
  fi
}
zoxide() { unfunction zoxide z zi; _load_zoxide; zoxide "$@"; }
z() { unfunction zoxide z zi; _load_zoxide; z "$@"; }
zi() { unfunction zoxide z zi; _load_zoxide; zi "$@"; }

# direnv - lazy load
direnv() {
  if command -v direnv &>/dev/null; then
    unfunction direnv
    eval "$(direnv hook zsh)"
    direnv "$@"
  else
    echo "direnv not installed" >&2
    return 1
  fi
}

# PostgreSQL
export PATH="/opt/homebrew/opt/postgresql@17/bin:$PATH"

# Lazy loading for heavy commands
aws() { unfunction aws; eval "$(aws --cli-auto-prompt 2>/dev/null)"; aws "$@"; }
gcloud() { unfunction gcloud; source "${BREW_PREFIX}/share/google-cloud-sdk/path.zsh.inc" 2>/dev/null; gcloud "$@"; }

# Flutter lazy load with common aliases
_load_flutter() {
  export FLUTTER_ROOT="$HOME/.flutter"
  export PATH="$FLUTTER_ROOT/bin:$PATH"
}
flutter() { unfunction flutter fl; _load_flutter; flutter "$@"; }
fl() { unfunction flutter fl; _load_flutter; flutter "$@"; }

# Starship - fast load
if command -v starship &>/dev/null; then
  eval "$(starship init zsh)"
fi
