{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": [
    "@tarquinen/opencode-dcp@latest"
  ],
  "agent": {
    "ask": {
      "mode": "primary",
      "prompt": "{file:./prompts/ask.txt}",
      "description": "A knowledgeable technical assistant focused on answering questions without changing your codebase",
      "permission": {
        "*": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "codesearch": "allow",
        "codebase_search": "allow",
        "question": "allow"
      },
    },
  },
  "mcp": {
    "mgrep": {
      "type": "local",
      "command": [
        "mgrep",
        "mcp"
      ],
      "enabled": true
    },
    "dart": {
      "type": "local",
      "command": [
        "dart",
        "mcp-server"
      ],
    },
  },
}
