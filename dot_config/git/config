[user]
	name = Cesar Posada
	email = cesarleonardo537@gmail.com
[color]
	diff = auto
	status = auto
	branch = auto
	ui = true
[core]
	excludesfile = ~/.config/gitignore
	editor = nvim
	pager = diff-so-fancy | less --tabs=4 -RF
[format]
	pretty=format:%C(yellow)%h%Creset -%C(red)%d%Creset %s %Cgreen(%ar) %C(bold blue)<%an>%Creset
[push]
	default = current
	autoSetupRemote = true
[stash]
	showPatch = true
[rebase]
	autostash = true
	updateRefs = true
[rerere]
	enabled = true
[column]
	ui = auto
[log]
	decorate = full
[pull]
	ff = only
	rebase = true
[init]
	defaultBranch = main
[gpg]
	program = gpg
