#!/bin/bash
set -e

# Colores para output
if [ -t 1 ] && [ -n "$TERM" ] && [ "$TERM" != "dumb" ]; then
    BLUE='\033[0;34m'
    GREEN='\033[0;32m'
    NC='\033[0m'
else
    BLUE=''
    GREEN=''
    NC=''
fi

printf "%b\n" "${BLUE}Generando configuración de opencommit...${NC}"

# Verificar que dcli está disponible
if ! command -v dcli >/dev/null 2>&1; then
    printf "dcli no está disponible, omitiendo generación de .opencommit\n"
    exit 0
fi

# Obtener API key
cd ~
API_KEY=$(dcli n "title=Openrouter API KEY" 2>/dev/null || echo "")

cat > "$HOME/.opencommit" << 'EOF'
OCO_TOKENS_MAX_INPUT=8192
OCO_TOKENS_MAX_OUTPUT=1000
OCO_DESCRIPTION=false
OCO_EMOJI=false
OCO_MODEL=openai/gpt-5.4-nano
OCO_LANGUAGE=en
OCO_MESSAGE_TEMPLATE_PLACEHOLDER=$msg
OCO_PROMPT_MODULE=conventional-commit
OCO_AI_PROVIDER=openrouter
OCO_ONE_LINE_COMMIT=false
OCO_TEST_MOCK_TYPE=commit-message
OCO_WHY=false
OCO_OMIT_SCOPE=false
OCO_GITPUSH=false
OCO_HOOK_AUTO_UNCOMMENT=false
EOF

# Agregar API key
if [ -n "$API_KEY" ]; then
    echo "OCO_API_KEY=$API_KEY" >> "$HOME/.opencommit"
else
    echo "OCO_API_KEY=" >> "$HOME/.opencommit"
fi

printf "%b\n" "${GREEN}✓ Configuración de opencommit generada${NC}"
