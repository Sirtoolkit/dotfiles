#!{{ lookPath "sh" }}

{{ if eq .chezmoi.os "darwin" -}}
set -e

# Añadir Homebrew al PATH
export PATH=/opt/homebrew/bin:$PATH

# Colores para output
if [ -t 1 ] && [ -n "$TERM" ] && [ "$TERM" != "dumb" ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    NC='\033[0m' # No Color
else
    RED=''
    GREEN=''
    YELLOW=''
    BLUE=''
    NC=''
fi

# Función para logging con colores
log_info() {
    printf "%b\n" "${BLUE}ℹ️  $1${NC}"
}

log_success() {
    printf "%b\n" "${GREEN}✅ $1${NC}"
}

log_warning() {
    printf "%b\n" "${YELLOW}⚠️  $1${NC}"
}

log_error() {
    printf "%b\n" "${RED}❌ $1${NC}"
}

log_step() {
    printf "\n%b\n" "${BLUE}🚀 $1${NC}"
}

# Verificar que estamos en macOS
if [ "$(uname -s)" != "Darwin" ]; then
    log_error "Este script solo funciona en macOS"
    exit 1
fi

# Función para configuración final
final_setup() {
    log_step "Configuración final..."

    # Configurar Git para usar gh como helper de credenciales
    if command -v gh >/dev/null 2>&1; then
        log_info "Configurando Git para usar GitHub CLI como helper de credenciales..."
        git config --global --unset-all credential.https://github.com.helper >/dev/null 2>&1 || true
        git config --global --unset-all credential.https://gist.github.com.helper >/dev/null 2>&1 || true
        git config --global credential.https://github.com.helper "!$(which gh) auth git-credential"
        git config --global credential.https://gist.github.com.helper "!$(which gh) auth git-credential"
        log_success "Git configurado para usar GitHub CLI"
    else
        log_warning "GitHub CLI (gh) no encontrado, saltando configuración de credenciales"
    fi

    # Cambiar shell por defecto a fish si no lo es ya
    if [ "$SHELL" != "/bin/fish" ] && [ "$SHELL" != "/usr/bin/fish" ] && [ "$SHELL" != "/opt/homebrew/bin/fish" ]; then
        if command -v fish >/dev/null 2>&1; then
            FISH_PATH="$(which fish)"
            # Añadir fish a /etc/shells si no está presente
            if ! grep -q "^${FISH_PATH}$" /etc/shells; then
                log_info "Añadiendo ${FISH_PATH} a /etc/shells..."
                echo "${FISH_PATH}" | sudo tee -a /etc/shells >/dev/null
                log_success "${FISH_PATH} añadido a /etc/shells"
            fi
            log_info "Cambiando shell por defecto a fish..."
            chsh -s "${FISH_PATH}"
            log_success "Shell cambiado a fish"
        else
            log_warning "fish no está disponible, manteniendo shell actual"
        fi
    else
        log_success "fish ya es el shell por defecto"
    fi

    # Activar servicio borders si no está ya activado
    if command -v brew >/dev/null 2>&1; then
        log_info "Verificando estado del servicio borders..."
        if brew services list | grep "^borders" | grep -q "started"; then
            log_info "Servicio borders ya está activado"
        else
            log_info "Activando servicio borders..."
            brew services start borders
            log_success "Servicio borders activado"
        fi
    else
        log_warning "Homebrew no encontrado, no se puede activar borders"
    fi
}

# Función para mostrar resumen final
show_summary() {
    log_step "🎉 ¡Aplicación de dotfiles completada!"
    
    printf "\n%b\n" "${GREEN}✅ Chezmoi aplicó exitosamente tus dotfiles${NC}"
    printf "\n%b\n" "${BLUE}📋 Archivos aplicados:${NC}"
    echo "  • Todos los archivos de configuración en tu directorio home"
    echo "  • Scripts de instalación ejecutados"
    
    printf "\n%b\n" "${YELLOW}💡 Comandos útiles:${NC}"
    echo "  • chezmoi apply - Aplicar cambios nuevamente"
    echo "  • chezmoi status - Ver estado de archivos"
    echo "  • chezmoi edit ~/.file - Editar archivos gestionados"
    
    printf "\n%b\n\n" "${GREEN}🚀 ¡Tu configuración está lista!${NC}"
}

# Función principal
main() {
    log_step "🍎 Iniciando configuración final y resumen"
    
    # Verificar que no se ejecute como root
    if [ "$EUID" -eq 0 ]; then
        log_warning "No ejecutes este script como root."
    fi
    
    # Configuración final
    final_setup
    
    # Mostrar resumen
    show_summary
}

# Ejecutar función principal
main "$@"
{{ end -}}
