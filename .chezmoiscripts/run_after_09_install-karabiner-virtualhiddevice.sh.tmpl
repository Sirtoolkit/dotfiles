#!{{ lookPath "bash" }}

{{ if eq .chezmoi.os "darwin" -}}

# Colores para output
if [ -t 1 ] && [ -n "$TERM" ] && [ "$TERM" != "dumb" ]; then
    BLUE='\033[0;34m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    RED='\033[0;31m'
    NC='\033[0m'
else
    BLUE=''
    GREEN=''
    YELLOW=''
    RED=''
    NC=''
fi

# Configuración
VERSION="6.12.0"
PKG_NAME="Karabiner-DriverKit-VirtualHIDDevice-${VERSION}.pkg"
DOWNLOAD_URL="https://github.com/pqrs-org/Karabiner-DriverKit-VirtualHIDDevice/releases/download/v${VERSION}/${PKG_NAME}"
DOWNLOAD_DIR="$HOME/Downloads"
PKG_PATH="$DOWNLOAD_DIR/$PKG_NAME"
MANAGER_APP="/Applications/.Karabiner-VirtualHIDDevice-Manager.app"
DAEMON_PATH="/Library/Application Support/org.pqrs/Karabiner-DriverKit-VirtualHIDDevice/Applications/Karabiner-VirtualHIDDevice-Daemon.app"

# Verificar si ya está instalado
if [ -d "$MANAGER_APP" ]; then
    printf "%b\n" "${GREEN}✓ Karabiner-VirtualHIDDevice ya está instalado${NC}"
else
    # Descargar el paquete si no existe
    if [ ! -f "$PKG_PATH" ]; then
        printf "%b\n" "${BLUE}Descargando Karabiner-VirtualHIDDevice ${VERSION}...${NC}"
        curl -fsSL "$DOWNLOAD_URL" -o "$PKG_PATH" || {
            printf "%b\n" "${RED}✗ Error descargando el paquete${NC}"
        }
        [ -f "$PKG_PATH" ] && printf "%b\n" "${GREEN}✓ Descarga completada${NC}"
    else
        printf "%b\n" "${YELLOW}⚑ Usando paquete existente: ${PKG_PATH}${NC}"
    fi

    # Instalar el paquete si existe (requiere sudo)
    if [ -f "$PKG_PATH" ]; then
        printf "%b\n" "${BLUE}Instalando Karabiner-VirtualHIDDevice...${NC}"
        printf "%b\n" "${YELLOW}  Se requiere contraseña de administrador${NC}"
        if sudo installer -pkg "$PKG_PATH" -target / 2>/dev/null; then
            printf "%b\n" "${GREEN}✓ Instalación completada${NC}"
        else
            printf "%b\n" "${RED}✗ Error en la instalación${NC}"
        fi
    fi

    # Activar el driver
    if [ -d "$MANAGER_APP" ]; then
        printf "%b\n" "${BLUE}Activando driver...${NC}"
        "$MANAGER_APP/Contents/MacOS/Karabiner-VirtualHIDDevice-Manager" activate 2>/dev/null || true
        printf "%b\n" "${GREEN}✓ Driver activado${NC}"
    fi

    # Limpiar archivo descargado
    rm -f "$PKG_PATH"

    printf "%b\n" "${GREEN}✓ Karabiner-VirtualHIDDevice instalado${NC}"
fi

# Configurar el daemon como servicio de sistema (siempre, no solo en instalación)
DAEMON_BIN="/Library/Application Support/org.pqrs/Karabiner-DriverKit-VirtualHIDDevice/Applications/Karabiner-VirtualHIDDevice-Daemon.app/Contents/MacOS/Karabiner-VirtualHIDDevice-Daemon"
LAUNCHD_PLIST="/Library/LaunchDaemons/org.pqrs.karabiner.virtualhiddevice-daemon.plist"

if [ -f "$DAEMON_BIN" ]; then
    if [ ! -f "$LAUNCHD_PLIST" ]; then
        printf "%b\n" "${BLUE}Configurando daemon como servicio de sistema...${NC}"

        sudo tee "$LAUNCHD_PLIST" > /dev/null << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>org.pqrs.karabiner.virtualhiddevice-daemon</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Library/Application Support/org.pqrs/Karabiner-DriverKit-VirtualHIDDevice/Applications/Karabiner-VirtualHIDDevice-Daemon.app/Contents/MacOS/Karabiner-VirtualHIDDevice-Daemon</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/dev/null</string>
    <key>StandardErrorPath</key>
    <string>/dev/null</string>
</dict>
</plist>
EOF

        sudo launchctl load "$LAUNCHD_PLIST"
        sleep 1
        printf "%b\n" "${GREEN}✓ Daemon configurado y corriendo como servicio${NC}"
    else
        # Verificar si está corriendo
        if ! sudo launchctl list org.pqrs.karabiner.virtualhiddevice-daemon 2>/dev/null | grep -q "PID"; then
            printf "%b\n" "${BLUE}Reiniciando daemon...${NC}"
            sudo launchctl unload "$LAUNCHD_PLIST" 2>/dev/null || true
            sudo launchctl load "$LAUNCHD_PLIST"
            printf "%b\n" "${GREEN}✓ Daemon reiniciado${NC}"
        fi
    fi
fi

# Configurar sudoers para kanata sin password
CURRENT_USER="$(whoami)"
SUDOERS_FILE="/etc/sudoers.d/kanata-${CURRENT_USER}"

if [ ! -f "$SUDOERS_FILE" ]; then
    printf "%b\n" "${BLUE}Configurando sudoers para kanata...${NC}"
    echo "${CURRENT_USER} ALL=(ALL) NOPASSWD: /opt/homebrew/bin/kanata" | sudo tee "$SUDOERS_FILE" > /dev/null
    echo "${CURRENT_USER} ALL=(ALL) NOPASSWD: /usr/bin/pkill kanata" | sudo tee -a "$SUDOERS_FILE" > /dev/null
    sudo chmod 440 "$SUDOERS_FILE"
    printf "%b\n" "${GREEN}✓ Configuración sudoers completada${NC}"
fi

printf "%b\n" "${GREEN}✓ Karabiner-VirtualHIDDevice listo para usar${NC}"

{{ end -}}
