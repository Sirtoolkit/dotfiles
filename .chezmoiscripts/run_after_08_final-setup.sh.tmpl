#!{{ lookPath "sh" }}

{{ if eq .chezmoi.os "darwin" -}}
set -e

# Añadir Homebrew al PATH
export PATH=/opt/homebrew/bin:$PATH

# Colores para output
if [ -t 1 ] && [ -n "$TERM" ] && [ "$TERM" != "dumb" ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    NC='\033[0m' # No Color
else
    RED=''
    GREEN=''
    YELLOW=''
    BLUE=''
    NC=''
fi

# Función para logging con colores
log_info() {
    printf "%b\n" "${BLUE}→ $1${NC}"
}

log_success() {
    printf "%b\n" "${GREEN}✓ $1${NC}"
}

log_warning() {
    printf "%b\n" "${YELLOW}⚠ $1${NC}"
}

log_error() {
    printf "%b\n" "${RED}✗ $1${NC}"
}

log_step() {
    printf "\n%b\n" "${BLUE}→ $1${NC}"
}

# Verificar que estamos en macOS
if [ "$(uname -s)" != "Darwin" ]; then
    log_error "Este script solo funciona en macOS"
    exit 1
fi

# Función para configuración final
final_setup() {
    log_step "Final"

    # Configurar Git para usar gh como helper de credenciales
    if command -v gh >/dev/null 2>&1; then
        log_info "Configurando credenciales Git con GitHub CLI"
        git config --global --unset-all credential.https://github.com.helper >/dev/null 2>&1 || true
        git config --global --unset-all credential.https://gist.github.com.helper >/dev/null 2>&1 || true
        git config --global credential.https://github.com.helper "!$(which gh) auth git-credential"
        git config --global credential.https://gist.github.com.helper "!$(which gh) auth git-credential"
        log_success "Git usa gh como credential helper"
    else
        log_warning "gh no encontrado; se omiten credenciales Git"
    fi

    # Cambiar shell por defecto a fish si no lo es ya
    if [ "$SHELL" != "/bin/fish" ] && [ "$SHELL" != "/usr/bin/fish" ] && [ "$SHELL" != "/opt/homebrew/bin/fish" ]; then
        if command -v fish >/dev/null 2>&1; then
            FISH_PATH="$(which fish)"
            # Añadir fish a /etc/shells si no está presente
            if ! grep -q "^${FISH_PATH}$" /etc/shells; then
                log_info "Añadiendo ${FISH_PATH} a /etc/shells"
                echo "${FISH_PATH}" | sudo tee -a /etc/shells >/dev/null
                log_success "${FISH_PATH} añadido a /etc/shells"
            fi
            log_info "Cambiando shell por defecto a fish"
            chsh -s "${FISH_PATH}"
            log_success "fish configurado como shell por defecto"
        else
            log_warning "fish no está disponible, manteniendo shell actual"
        fi
    else
        log_success "fish ya es el shell por defecto"
    fi

    # Activar servicio borders si no está ya activado
    if command -v brew >/dev/null 2>&1; then
        log_info "Verificando servicio borders"
        if brew services list | grep "^borders" | grep -q "started"; then
            log_success "borders activo"
        else
            log_info "Activando servicio borders"
            if brew services start borders >/dev/null 2>&1 || brew services restart borders >/dev/null 2>&1; then
                log_success "borders activado"
            else
                log_warning "No se pudo activar borders; ejecuta 'brew services restart borders' manualmente"
            fi
        fi
    else
        log_warning "Homebrew no encontrado; se omite borders"
    fi
}

# Función para mostrar resumen final
show_summary() {
    log_step "Resumen"
    
    printf "%b\n" "${GREEN}✓ Dotfiles aplicados${NC}"
    printf "\n%b\n" "${BLUE}Instalaciones gestionadas:${NC}"
    echo "  - Nix / nix-darwin"
    echo "  - Mise"
    echo "  - PNPM global: nx, opencommit, expo, @nestjs/cli, @mixedbread/mgrep"
    echo "  - tmux y plugins"
    echo "  - Android SDK + Flutter"
    echo "  - opencommit"
    echo "  - Karabiner VirtualHID + kanata"
    echo "  - Local apps: cursive, cauce, vsql"
    echo "  - Git credentials, fish y borders"
    
    printf "\n%b\n" "${YELLOW}Comandos útiles:${NC}"
    echo "  - chezmoi apply           Reaplicar dotfiles"
    echo "  - chezmoi status          Ver cambios pendientes"
    echo "  - local-apps list        Ver comandos locales gestionados"
    echo "  - chezmoi edit ~/.file    Editar archivo gestionado"
    
    printf "\n%b\n\n" "${GREEN}✓ Configuración lista${NC}"
}

# Función principal
main() {
    log_step "Setup final"
    
    # Verificar que no se ejecute como root
    if [ "$EUID" -eq 0 ]; then
        log_warning "No ejecutes este script como root."
    fi
    
    # Configuración final
    final_setup
    
    # Mostrar resumen
    show_summary
}

# Ejecutar función principal
main "$@"
{{ end -}}
