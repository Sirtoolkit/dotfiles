{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash
set -euo pipefail
umask 077

# Colores para output
if [ -t 1 ] && [ -n "$TERM" ] && [ "$TERM" != "dumb" ]; then
    BLUE='\033[0;34m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    NC='\033[0m'
else
    BLUE=''
    GREEN=''
    YELLOW=''
    NC=''
fi

printf "\n%b\n" "${BLUE}→ opencommit${NC}"
printf "%b\n" "${BLUE}→ Generando ~/.opencommit${NC}"

# Verificar que dcli está disponible
if ! command -v dcli >/dev/null 2>&1; then
    printf "%b\n" "${YELLOW}⚠ dcli no está disponible; se omite ~/.opencommit${NC}"
    exit 0
fi

# Obtener API key
API_KEY=$(dcli n "title=Openrouter API KEY" 2>/dev/null || echo "")
OPENCOMMIT_FILE="$HOME/.opencommit"
OPENCOMMIT_TMP="$(mktemp)"
cleanup_opencommit_tmp() {
    [ -n "${OPENCOMMIT_TMP:-}" ] && rm -f "$OPENCOMMIT_TMP"
}
trap cleanup_opencommit_tmp EXIT

cat > "$OPENCOMMIT_TMP" << 'EOF'
OCO_TOKENS_MAX_INPUT=8192
OCO_TOKENS_MAX_OUTPUT=1000
OCO_DESCRIPTION=false
OCO_EMOJI=false
OCO_MODEL=openai/gpt-5.4-nano
OCO_LANGUAGE=en
OCO_MESSAGE_TEMPLATE_PLACEHOLDER=$msg
OCO_PROMPT_MODULE=conventional-commit
OCO_AI_PROVIDER=openrouter
OCO_ONE_LINE_COMMIT=false
OCO_TEST_MOCK_TYPE=commit-message
OCO_WHY=false
OCO_OMIT_SCOPE=false
OCO_GITPUSH=false
OCO_HOOK_AUTO_UNCOMMENT=false
EOF

# Agregar API key
if [ -n "$API_KEY" ]; then
    printf "OCO_API_KEY=%s\n" "$API_KEY" >> "$OPENCOMMIT_TMP"
else
    printf "OCO_API_KEY=\n" >> "$OPENCOMMIT_TMP"
fi

chmod 600 "$OPENCOMMIT_TMP"
if [ -f "$OPENCOMMIT_FILE" ] && cmp -s "$OPENCOMMIT_TMP" "$OPENCOMMIT_FILE"; then
    printf "%b\n" "${GREEN}✓ opencommit sin cambios${NC}"
else
    mv "$OPENCOMMIT_TMP" "$OPENCOMMIT_FILE"
    OPENCOMMIT_TMP=""
    printf "%b\n" "${GREEN}✓ opencommit actualizado${NC}"
fi

printf "%b\n" "${GREEN}✓ opencommit listo${NC}"
{{ end -}}
