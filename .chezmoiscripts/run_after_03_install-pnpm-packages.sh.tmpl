#!/bin/bash
set -e

# Colores para output
if [ -t 1 ] && [ -n "$TERM" ] && [ "$TERM" != "dumb" ]; then
    BLUE='\033[0;34m'
    GREEN='\033[0;32m'
    RED='\033[0;31m'
    NC='\033[0m'
else
    BLUE=''
    GREEN=''
    RED=''
    NC=''
fi

if ! command -v pnpm >/dev/null 2>&1; then
  printf "\n%b\n" "${BLUE}→ PNPM global${NC}"
  printf "%b\n" "${RED}✗ pnpm no está instalado; no se pueden instalar paquetes globales${NC}"
  exit 1
fi

printf "\n%b\n" "${BLUE}→ PNPM global${NC}"

# Configurar PNPM_HOME
if [ -z "$PNPM_HOME" ]; then
  export PNPM_HOME="$HOME/Library/pnpm"
fi

# Añadir al PATH
if [[ ":$PATH:" != *":$PNPM_HOME:"* ]]; then
  export PATH="$PNPM_HOME:$PATH"
fi

mkdir -p "$PNPM_HOME"

# Instalar paquetes globales
packages="nx:nx opencommit expo:expo @nestjs/cli:nest @mixedbread/mgrep:mgrep"

for package_info in $packages; do
  IFS=':' read -r package cmd <<< "$package_info"
  
  if pnpm list -g --json "$package" 2>/dev/null | grep -q "\"$package\""; then
    printf "%b\n" "${GREEN}✓ $package${NC}"
  else
    printf "%b\n" "${BLUE}→ Instalando $package${NC}"
    pnpm add -g "$package"
  fi
done

printf "%b\n" "${GREEN}✓ PNPM global listo${NC}"
