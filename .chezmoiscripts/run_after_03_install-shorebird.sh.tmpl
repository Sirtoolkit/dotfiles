#!{{ lookPath "bash" }}

{{ if eq .chezmoi.os "darwin" -}}
set -e

# Colores para output
if [ -t 1 ] && [ -n "$TERM" ] && [ "$TERM" != "dumb" ]; then
    BLUE='\033[0;34m'
    GREEN='\033[0;32m'
    RED='\033[0;31m'
    NC='\033[0m'
else
    BLUE=''
    GREEN=''
    RED=''
    NC=''
fi

log_info() {
    printf "%b\n" "${BLUE}→ $1${NC}"
}

log_success() {
    printf "%b\n" "${GREEN}✓ $1${NC}"
}

log_error() {
    printf "%b\n" "${RED}✗ $1${NC}"
}

SHOREBIRD_HOME="${XDG_CONFIG_HOME:-$HOME/.config}/shorebird"
export PATH="$SHOREBIRD_HOME/bin:$HOME/.shorebird/bin:/opt/homebrew/bin:/usr/local/bin:$PATH"

printf "\n%b\n" "${BLUE}→ Shorebird${NC}"

if command -v shorebird >/dev/null 2>&1 || [ -x "$SHOREBIRD_HOME/bin/shorebird" ] || [ -x "$HOME/.shorebird/bin/shorebird" ]; then
    log_success "shorebird"
    exit 0
fi

if ! command -v curl >/dev/null 2>&1; then
    log_error "curl no está disponible; no se puede instalar Shorebird"
    exit 1
fi

log_info "Instalando Shorebird CLI"
curl --proto '=https' --tlsv1.2 https://raw.githubusercontent.com/shorebirdtech/install/main/install.sh -sSf | bash

if command -v shorebird >/dev/null 2>&1 || [ -x "$SHOREBIRD_HOME/bin/shorebird" ] || [ -x "$HOME/.shorebird/bin/shorebird" ]; then
    log_success "shorebird instalado"
else
    log_error "Shorebird se instaló, pero el comando no quedó disponible"
    exit 1
fi
{{ end -}}
