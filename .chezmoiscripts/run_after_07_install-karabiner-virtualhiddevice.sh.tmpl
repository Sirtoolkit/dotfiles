#!{{ lookPath "bash" }}

{{ if eq .chezmoi.os "darwin" -}}
export PATH="/opt/homebrew/bin:/usr/local/bin:/run/current-system/sw/bin:$PATH"

# Colores para output
if [ -t 1 ] && [ -n "$TERM" ] && [ "$TERM" != "dumb" ]; then
    BLUE='\033[0;34m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    RED='\033[0;31m'
    NC='\033[0m'
else
    BLUE=''
    GREEN=''
    YELLOW=''
    RED=''
    NC=''
fi

# Configuración
VERSION="6.12.0"
PKG_NAME="Karabiner-DriverKit-VirtualHIDDevice-${VERSION}.pkg"
DOWNLOAD_URL="https://github.com/pqrs-org/Karabiner-DriverKit-VirtualHIDDevice/releases/download/v${VERSION}/${PKG_NAME}"
DOWNLOAD_DIR="$HOME/Downloads"
PKG_PATH="$DOWNLOAD_DIR/$PKG_NAME"
MANAGER_APP="/Applications/.Karabiner-VirtualHIDDevice-Manager.app"
DAEMON_PATH="/Library/Application Support/org.pqrs/Karabiner-DriverKit-VirtualHIDDevice/Applications/Karabiner-VirtualHIDDevice-Daemon.app"
DAEMON_BIN="/Library/Application Support/org.pqrs/Karabiner-DriverKit-VirtualHIDDevice/Applications/Karabiner-VirtualHIDDevice-Daemon.app/Contents/MacOS/Karabiner-VirtualHIDDevice-Daemon"
LAUNCHD_PLIST="/Library/LaunchDaemons/org.pqrs.karabiner.virtualhiddevice-daemon.plist"
CURRENT_USER="$(whoami)"
SUDOERS_FILE="/etc/sudoers.d/kanata-${CURRENT_USER}"
if [ -x "/opt/homebrew/bin/kanata" ]; then
    KANATA_SOURCE_BIN="/opt/homebrew/bin/kanata"
else
    KANATA_SOURCE_BIN="$(command -v kanata || true)"
fi
KANATA_STABLE_BIN="/usr/local/bin/kanata"
KANATA_STABLE_UPDATED=0


printf "\n%b\n" "${BLUE}→ Karabiner${NC}"


# Verificar si ya está instalado
if [ -d "$MANAGER_APP" ]; then
    printf "%b\n" "${GREEN}✓ VirtualHID instalado${NC}"
else
    # Descargar el paquete si no existe
    if [ ! -f "$PKG_PATH" ]; then
        printf "%b\n" "${BLUE}→ Descargando VirtualHID ${VERSION}${NC}"
        curl -fsSL "$DOWNLOAD_URL" -o "$PKG_PATH" || {
            printf "%b\n" "${RED}✗ Error descargando el paquete${NC}"
        }
        [ -f "$PKG_PATH" ] && printf "%b\n" "${GREEN}✓ Descarga completada${NC}"
    else
        printf "%b\n" "${YELLOW}⚠ Usando paquete existente: ${PKG_PATH}${NC}"
    fi

    # Instalar el paquete si existe (requiere sudo)
    if [ -f "$PKG_PATH" ]; then
        printf "%b\n" "${BLUE}→ Instalando VirtualHID${NC}"
        printf "%b\n" "${YELLOW}  Se requiere contraseña de administrador${NC}"
        if sudo installer -pkg "$PKG_PATH" -target / 2>/dev/null; then
            printf "%b\n" "${GREEN}✓ Instalación completada${NC}"
        else
            printf "%b\n" "${RED}✗ Error en la instalación${NC}"
        fi
    fi

    # Activar el driver
    if [ -d "$MANAGER_APP" ]; then
        printf "%b\n" "${BLUE}→ Activando driver VirtualHID${NC}"
        "$MANAGER_APP/Contents/MacOS/Karabiner-VirtualHIDDevice-Manager" activate 2>/dev/null || true
        printf "%b\n" "${GREEN}✓ Driver activado${NC}"
    fi

    # Limpiar archivo descargado
    rm -f "$PKG_PATH"

    printf "%b\n" "${GREEN}✓ Karabiner-VirtualHIDDevice instalado${NC}"
fi

if [ -f "$DAEMON_BIN" ]; then
    if [ ! -f "$LAUNCHD_PLIST" ]; then
        printf "%b\n" "${BLUE}→ Configurando LaunchDaemon de VirtualHID${NC}"

        sudo tee "$LAUNCHD_PLIST" > /dev/null << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>org.pqrs.karabiner.virtualhiddevice-daemon</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Library/Application Support/org.pqrs/Karabiner-DriverKit-VirtualHIDDevice/Applications/Karabiner-VirtualHIDDevice-Daemon.app/Contents/MacOS/Karabiner-VirtualHIDDevice-Daemon</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/dev/null</string>
    <key>StandardErrorPath</key>
    <string>/dev/null</string>
</dict>
</plist>
EOF

        sudo launchctl load "$LAUNCHD_PLIST"
        sleep 1
        printf "%b\n" "${GREEN}✓ LaunchDaemon activo${NC}"
    else
        # Verificar si está corriendo
        if ! sudo launchctl list org.pqrs.karabiner.virtualhiddevice-daemon 2>/dev/null | grep -q "PID"; then
            printf "%b\n" "${BLUE}→ Reiniciando LaunchDaemon de VirtualHID${NC}"
            sudo launchctl unload "$LAUNCHD_PLIST" 2>/dev/null || true
            sudo launchctl load "$LAUNCHD_PLIST"
            printf "%b\n" "${GREEN}✓ LaunchDaemon reiniciado${NC}"
        fi
    fi
fi

# Instalar kanata en una ruta estable para permisos TCC de macOS.
# Evita depender de /opt/homebrew/Cellar/kanata/<version>/bin/kanata.
if [ -n "$KANATA_SOURCE_BIN" ] && [ -x "$KANATA_SOURCE_BIN" ]; then
    if [ "$KANATA_SOURCE_BIN" != "$KANATA_STABLE_BIN" ] && { [ ! -x "$KANATA_STABLE_BIN" ] || ! cmp -s "$KANATA_SOURCE_BIN" "$KANATA_STABLE_BIN"; }; then
        printf "%b\n" "${BLUE}→ Instalando kanata estable en ${KANATA_STABLE_BIN}${NC}"
        sudo install -m 0755 "$KANATA_SOURCE_BIN" "$KANATA_STABLE_BIN"
        KANATA_STABLE_UPDATED=1
        printf "%b\n" "${GREEN}✓ kanata estable listo${NC}"
    else
        printf "%b\n" "${GREEN}✓ kanata estable listo${NC}"
    fi
else
    printf "%b\n" "${YELLOW}⚠ kanata no encontrado; se omite ruta estable${NC}"
fi

# Configurar sudoers para kanata sin password
SUDOERS_TMP="$(mktemp)"
{
    printf '%s\n' "${CURRENT_USER} ALL=(ALL) NOPASSWD: ${KANATA_STABLE_BIN}"
    printf '%s\n' "${CURRENT_USER} ALL=(ALL) NOPASSWD: /usr/bin/pkill kanata"
} > "$SUDOERS_TMP"

if [ ! -f "$SUDOERS_FILE" ] || ! sudo cmp -s "$SUDOERS_TMP" "$SUDOERS_FILE"; then
    printf "%b\n" "${BLUE}→ Configurando sudoers de kanata${NC}"
    sudo install -m 0440 -o root -g wheel "$SUDOERS_TMP" "$SUDOERS_FILE"
    printf "%b\n" "${GREEN}✓ sudoers de kanata listo${NC}"
fi
rm -f "$SUDOERS_TMP"

if [ "$KANATA_STABLE_UPDATED" -eq 1 ]; then
    printf "%b\n" "${YELLOW}⚠ macOS requiere aprobar ${KANATA_STABLE_BIN} en Input Monitoring y Accessibility${NC}"
    open "x-apple.systempreferences:com.apple.preference.security?Privacy_ListenEvent" >/dev/null 2>&1 || true
    open "x-apple.systempreferences:com.apple.preference.security?Privacy_Accessibility" >/dev/null 2>&1 || true
fi

printf "%b\n" "${GREEN}✓ Karabiner listo${NC}"

{{ end -}}
